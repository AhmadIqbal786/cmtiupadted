pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Snapshot.sol";

contract QuantumToken is ERC20, ERC20Burnable, Pausable, Ownable, ERC20Snapshot {
    uint256 public constant MAX_SUPPLY = 1000000000 * 10**18; // 1 billion tokens
    uint256 public constant ICO_SUPPLY = 400000000 * 10**18; // 40% for ICO
    uint256 public constant TEAM_SUPPLY = 150000000 * 10**18; // 15% for team
    uint256 public constant ECOSYSTEM_SUPPLY = 200000000 * 10**18; // 20% for ecosystem
    uint256 public constant LIQUIDITY_SUPPLY = 150000000 * 10**18; // 15% for liquidity
    
    uint256 public icoStartTime;
    uint256 public icoEndTime;
    uint256 public icoRate = 10000; // 1 ETH = 10,000 QTN
    uint256 public icoMinContribution = 0.1 ether;
    uint256 public icoMaxContribution = 100 ether;
    uint256 public icoRaised;
    uint256 public icoSoftCap = 2000 ether; // $2M at $1000/ETH
    uint256 public icoHardCap = 10000 ether; // $10M at $1000/ETH
    
    mapping(address => uint256) public contributions;
    mapping(address => bool) public whitelist;
    
    bool public teamTokensReleased = false;
    uint256 public teamVestingStart;
    uint256 public constant TEAM_VESTING_DURATION = 730 days; // 2 years
    
    event TokensPurchased(address indexed buyer, uint256 amount, uint256 tokens);
    event WhitelistUpdated(address indexed account, bool status);
    event ICOStarted(uint256 startTime, uint256 endTime);
    event ICOEnded(uint256 raised, bool success);

    constructor() ERC20("QuantumToken", "QTN") {
        _mint(address(this), ICO_SUPPLY + ECOSYSTEM_SUPPLY + LIQUIDITY_SUPPLY);
        _mint(owner(), TEAM_SUPPLY);
        
        // Initial burn of 10%
        _burn(owner(), TEAM_SUPPLY / 10);
    }

    function startICO(uint256 _durationInDays) external onlyOwner {
        require(icoStartTime == 0, "ICO already started");
        
        icoStartTime = block.timestamp;
        icoEndTime = block.timestamp + (_durationInDays * 1 days);
        
        emit ICOStarted(icoStartTime, icoEndTime);
    }

    function buyTokens() external payable whenNotPaused {
        require(icoStartTime > 0 && block.timestamp >= icoStartTime, "ICO not started");
        require(block.timestamp <= icoEndTime, "ICO ended");
        require(whitelist[msg.sender], "Address not whitelisted");
        require(msg.value >= icoMinContribution, "Contribution too low");
        require(contributions[msg.sender] + msg.value <= icoMaxContribution, "Contribution exceeds limit");
        require(icoRaised + msg.value <= icoHardCap, "Hard cap reached");
        
        uint256 tokens = msg.value * icoRate;
        require(tokens <= balanceOf(address(this)), "Not enough tokens left");
        
        contributions[msg.sender] += msg.value;
        icoRaised += msg.value;
        
        _transfer(address(this), msg.sender, tokens);
        
        emit TokensPurchased(msg.sender, msg.value, tokens);
    }

    function addToWhitelist(address[] calldata _addresses) external onlyOwner {
        for (uint256 i = 0; i < _addresses.length; i++) {
            whitelist[_addresses[i]] = true;
            emit WhitelistUpdated(_addresses[i], true);
        }
    }

    function removeFromWhitelist(address[] calldata _addresses) external onlyOwner {
        for (uint256 i = 0; i < _addresses.length; i++) {
            whitelist[_addresses[i]] = false;
            emit WhitelistUpdated(_addresses[i], false);
        }
    }

    function endICO() external onlyOwner {
        require(icoStartTime > 0, "ICO not started");
        require(block.timestamp > icoEndTime || icoRaised >= icoHardCap, "ICO not finished");
        
        bool success = icoRaised >= icoSoftCap;
        
        if (!success) {
            // Allow refunds if soft cap not reached
            // Implementation of refund mechanism would go here
        } else {
            teamVestingStart = block.timestamp;
        }
        
        emit ICOEnded(icoRaised, success);
    }

    function releaseTeamTokens() external onlyOwner {
        require(teamVestingStart > 0, "Vesting not started");
        require(!teamTokensReleased, "Team tokens already released");
        require(block.timestamp >= teamVestingStart + (6 * 30 days), "Cliff period not passed");
        
        uint256 vestedAmount = (TEAM_SUPPLY * (block.timestamp - teamVestingStart)) / TEAM_VESTING_DURATION;
        uint256 releasable = vestedAmount - balanceOf(owner());
        
        if (releasable > 0) {
            _transfer(owner(), msg.sender, releasable);
        }
        
        if (block.timestamp >= teamVestingStart + TEAM_VESTING_DURATION) {
            teamTokensReleased = true;
        }
    }

    function withdrawFunds() external onlyOwner {
        require(icoRaised >= icoSoftCap, "Soft cap not reached");
        require(block.timestamp > icoEndTime, "ICO not finished");
        
        uint256 balance = address(this).balance;
        payable(owner()).transfer(balance);
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }

    function snapshot() external onlyOwner {
        _snapshot();
    }

    function _beforeTokenTransfer(address from, address to, uint256 amount)
        internal
        whenNotPaused
        override(ERC20, ERC20Snapshot)
    {
        super._beforeTokenTransfer(from, to, amount);
    }
}